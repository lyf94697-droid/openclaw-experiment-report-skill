{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lyf94697-droid/openclaw-experiment-report-skill/schemas/report-profile.schema.json",
  "title": "OpenClaw report profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "displayName",
    "defaultStyleProfile",
    "metadataFields",
    "sectionFields",
    "imagePlacementDefaults",
    "detailProfiles"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "defaultStyleProfile": {
      "type": "string",
      "enum": ["auto", "default", "compact", "school"]
    },
    "defaultExperimentProperty": {
      "type": "string"
    },
    "metadataFields": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/labeledField" }
    },
    "extraLabels": {
      "type": "array",
      "items": { "$ref": "#/$defs/labeledField" }
    },
    "sectionFields": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sectionField" }
    },
    "extraSectionHeadings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "imagePlacementDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fallbackSectionOrder", "defaultCaptions", "filenameCaptionRules"],
      "properties": {
        "fallbackSectionOrder": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sectionId" }
        },
        "defaultCaptions": {
          "type": "object",
          "required": ["default"],
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          },
          "properties": {
            "default": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "filenameCaptionRules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern", "caption"],
            "properties": {
              "pattern": {
                "type": "string",
                "minLength": 1
              },
              "caption": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "fieldMapCompositeRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["matchAll", "blocks"],
        "properties": {
          "matchAll": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "blocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["heading", "sectionIds"],
              "properties": {
                "heading": {
                  "type": "string",
                  "minLength": 1
                },
                "sectionIds": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "$ref": "#/$defs/sectionId" }
                }
              }
            }
          }
        }
      }
    },
    "detailProfiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard", "full"],
      "properties": {
        "standard": { "$ref": "#/$defs/detailProfile" },
        "full": { "$ref": "#/$defs/detailProfile" }
      }
    },
    "paginationRiskThresholds": {
      "$ref": "#/$defs/paginationRiskThresholds"
    },
    "forbiddenPatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "sectionId": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "labeledField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label"],
      "properties": {
        "key": { "$ref": "#/$defs/identifier" },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "aliases": { "$ref": "#/$defs/aliases" }
      }
    },
    "sectionField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "heading", "aliases", "minChars"],
      "properties": {
        "key": { "$ref": "#/$defs/identifier" },
        "heading": {
          "type": "string",
          "minLength": 1
        },
        "aliases": { "$ref": "#/$defs/aliases" },
        "minChars": {
          "type": "object",
          "additionalProperties": false,
          "required": ["standard", "full"],
          "properties": {
            "standard": {
              "type": "integer",
              "minimum": 0
            },
            "full": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "detailProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minChars", "promptGuidance"],
      "properties": {
        "minChars": {
          "type": "integer",
          "minimum": 0
        },
        "promptGuidance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "paginationRiskThresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "longSectionChars": {
          "type": "integer",
          "minimum": 0
        },
        "denseSectionChars": {
          "type": "integer",
          "minimum": 0
        },
        "denseSectionParagraphs": {
          "type": "integer",
          "minimum": 0
        },
        "figureClusterRefs": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
